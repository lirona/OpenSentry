# Copy this file to `.dev.vars` (gitignored) for local `wrangler pages dev`
# runs. In production, set the same keys in the Cloudflare Pages dashboard
# under Settings -> Environment variables (marked as Encrypted / Secret).

# --- AI provider ---
AI_API_KEY=""
AI_MODEL=""
# --- API abuse protection ---
# Optional model-call concurrency. Defaults to 1 to avoid free-tier burst limits.
AI_AGENT_CONCURRENCY="1"
# Optional per-IP cooldown in milliseconds. Set to 0 to disable.
ANALYZE_IP_COOLDOWN_MS="15000"
# Optional global daily cap. Set to 0 to disable.
ANALYZE_DAILY_CAP="0"

# --- Etherscan V2 (unified multichain key) ---
# Etherscan V2 uses ONE key across all supported chains
# (Ethereum, Base, Arbitrum, Optimism, Polygon, ...).
ETHERSCAN_API_KEY=""
